flowchart TD
    A([Strategic Sourcing]) --> B[Spend Analysis]
    B --> C[Procurement Strategy]
    C --> D{Sole Source?}
    D --> |Yes| E[Draft Justification]
    D --> |No| F[Supplier Pre-Qual]
    E --> CHK1
    G --> H{Approved?}
    H --> |No| I[Revise]
    I --> G
    H --> |Yes| J[Direct Negotiation]
    F --> K[Market Research]
    K --> L[Longlist]
    L --> M[RFI]
    M --> N[RFI Eval]
    N --> O[Shortlist]
    O --> P[RFP]
    P --> Q[Q&A]
    Q --> R[Final Proposals]
    R --> S[Evaluation Panel]
    S --> T[Score]
    T --> CHK2
    U --> |No| V[Reject]
    U --> |Yes| W[Due Diligence]
    J --> W
    V --> P
    W --> X[Contract]
    X --> CHK3
    Y([Executed])

    %% ⚡ CHANGED SECTION — Compliance Officer lane with three checkpoints
    subgraph COMP["Compliance Officer"]
        direction TB
        CHK1{{"Conflict of Interest & Vendor Independence Review"}}
        CHK2{{"Scoring Integrity Verification"}}
        CHK3{{"ERP Access Control Review"}}
    end

    CHK1 --> G[Legal Review]
    CHK2 --> U{Above 75?}
    CHK3 --> Y

    %% ⚡ CHANGED SECTION — Audit records as data-object artifacts (not inline)
    DOC_SPEND>"Spend Analysis Record"]
    DOC_SOLESOURCE>"Sole Source Justification Record"]
    DOC_SCORECARD>"RFP Scorecard Record"]
    DOC_DD>"Due Diligence File"]
    DOC_CONTRACT>"Signed Contract Record"]

    B -.- DOC_SPEND
    E -.- DOC_SOLESOURCE
    T -.- DOC_SCORECARD
    W -.- DOC_DD
    X -.- DOC_CONTRACT

    %% ⚡ CHANGED SECTION — RACI annotations on the three big decisions
    RACI_D["RACI — Sole Source Decision
    R: Procurement Lead
    A: CPO
    C: Compliance Officer
    I: Finance"]
    D -.- RACI_D

    RACI_U["RACI — Scoring Decision
    R: Evaluation Panel
    A: CPO
    C: Compliance Officer
    I: Requesting Business Unit"]
    U -.- RACI_U

    RACI_X["RACI — Contract Execution
    R: Contract Manager
    A: CPO
    C: Legal Counsel, Compliance Officer
    I: Finance, IT Security"]
    X -.- RACI_X

    %% ⚡ CHANGED SECTION — Styling
    classDef checkpoint fill:#fff3cd,stroke:#d4a017,stroke-width:2px,color:#000
    classDef dataobj fill:#e8f4fd,stroke:#5b9bd5,stroke-width:1px,stroke-dasharray:5 5,color:#000
    classDef annotation fill:#fff,stroke:#999,stroke-width:1px,stroke-dasharray:3 3,color:#333,font-size:11px

    class CHK1,CHK2,CHK3 checkpoint
    class DOC_SPEND,DOC_SOLESOURCE,DOC_SCORECARD,DOC_DD,DOC_CONTRACT dataobj
    class RACI_D,RACI_U,RACI_X annotation

%% EXPLANATION:
%% Added a Compliance Officer subgraph (lane) containing three hexagonal checkpoint tasks: Conflict of Interest & Vendor Independence Review (inserted between Draft Justification and Legal Review), Scoring Integrity Verification (inserted between Score and the Above 75? gateway), and ERP Access Control Review (inserted between Contract and Executed). Five audit-trail data objects (Spend Analysis Record, Sole Source Justification Record, RFP Scorecard Record, Due Diligence File, Signed Contract Record) were attached as artifacts via dotted association lines to their source tasks, keeping them out of the sequence flow. RACI annotation nodes were added to the three major decision gateways (Sole Source?, Above 75?, Contract Execution) on dotted lines. All existing paths—sole source, competitive bidding, and reject-resubmit—remain unchanged.